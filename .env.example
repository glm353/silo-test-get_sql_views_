# Copy to .env (gitignored) and fill in. Only needed for `viewpull refresh` (the one live pull).
# Everything else runs offline against cache/ or fixtures/.

# AWS — the profile used for the live Glue/DynamoDB read. dev account is 484438948628.
AWS_PROFILE=
AWS_REGION=ap-southeast-2

# Okta SSO (only if you use --okta-login). Paste your full working command into OKTA_LOGIN_COMMAND,
# or set the parts below. See lineage-trace-analysis/.env.example for the canonical model.
OKTA_LOGIN_COMMAND=
OKTA_ORG_DOMAIN=
OKTA_OIDC_CLIENT_ID=
OKTA_AWS_ACCT_FED_APP_ID=
